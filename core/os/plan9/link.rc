#!/bin/rc
# Link Odin-generated objects: prog.o + entry.o + libodin_plan9.a
#
#   link [-o prog] file.N [more.N ...]
#
# Example:
#   ./link.rc -o myprog hello.7
#   → 7l -o myprog hello.7 entry.7 libodin_plan9.a

rfork e
cd `{pwd}

out=a.out
lib=libodin_plan9.a

switch ($1) {
case -o
	out=$2
	shift
	shift
}

suffix=`{echo $1 | sed 's/.*\.//'}
entry=entry.$suffix
ld=$suffix^l

exec $ld -o $out $* $entry $lib
