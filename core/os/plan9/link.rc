#!/bin/rc
# Link Odin-generated Plan 9 objects into an executable.
#
#   link [-o prog] file.$objtype [more.$objtype ...]
#
# Requires libodin_plan9.a and entry.$objtype (built by mk integration).
#
# Example on arm64 ($objtype=7, compiler 7c):
#   7c -Isrc -o myprog.7 examples/hello/hello.c
#   ./link.rc -o myprog myprog.7
#   — or reuse an existing object: ./link.rc -o myprog hello.7

rfork e

dir=`{pwd}
cd $dir

lib=libodin_plan9.a
out=a.out
entry=''

if (! ~ $objtype '' && ~ -f entry.$objtype)
	entry=entry.$objtype

if (~ $entry '') {
	for (f in entry.*) {
		if (~ -f $f) {
			entry=$f
			break
		}
	}
}

if (~ $entry '' || ! ~ -f $entry) {
	echo link: missing entry.$objtype — run mk integration in $dir >[1=2]
	echo link: looked in $dir for entry.* >[1=2]
	exit noentry
}
if (! ~ -f $lib) {
	echo link: missing $lib — run mk in $dir >[1=2]
	exit nolib
}

while (~ $#* 0) {
	if (~ $1 -o) {
		shift
		if (~ $#* 0) {
			echo 'link: -o needs a filename' >[1=2]
			exit usage
		}
		out=$1
		shift
	}
	if not
		break
}

if (~ $#* 0) {
	echo 'usage: link [-o prog] file.'$objtype' [...]' >[1=2]
	exit usage
}

for (o in $*) {
	if (! ~ -f $o) {
		echo link: missing $o >[1=2]
		exit nofile
	}
}

exec $LD -o $out $* $entry $lib
