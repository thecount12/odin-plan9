#!/bin/rc
# Build an Odin-generated (or hand-written) C program on Plan 9.
#
#   build.rc [-o prog] program.c
#
# Example:
#   ./cgen/cgen hello > hello.c
#   ./build.rc -o hello hello.c

rfork e
cd `{pwd}

out=program
cfile=''

switch ($1) {
case -o
	out=$2
	shift
	shift
	cfile=$1
}

if (~ $cfile '')
	cfile=$1

if (~ $cfile '') {
	echo 'usage: build.rc [-o prog] program.c' >[1=2]
	exit usage
}

stem=`{basename $cfile .c}

suffix=$O
if (~ $suffix '') {
	entry=`{ls entry.* >[2=1] | sed -n 1p}
	if (~ $entry '') {
		echo build: missing entry.* — run mk integration >[1=2]
		exit noentry
	}
	suffix=`{echo $entry | sed 's/.*\.//'}
}

cc=$CC
if (~ $cc '')
	cc=$suffix^c

obj=$stem.$suffix

$cc -Iinclude -Isrc -o $obj $cfile
if (! ~ $status '') {
	echo build: compile failed >[1=2]
	exit fail
}

exec ./link.rc -o $out $obj
