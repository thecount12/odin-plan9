#!/bin/rc
# Build an Odin-generated (or hand-written) C program on Plan 9.
#
#   build.rc [-o prog] program.c
#
# Example:
#   ./cgen/cgen hello > /tmp/hello.c
#   ./build.rc -o hello /tmp/hello.c

rfork e
cd `{pwd}

out=program
cfile=''

switch ($1) {
case -o
	if (~ $#* '<' 2) {
		echo 'usage: build.rc [-o prog] program.c' >[1=2]
		exit usage
	}
	out=$2
	cfile=$3
case *
	if (~ $#* 1)
		cfile=$1
	if not {
		echo 'usage: build.rc [-o prog] program.c' >[1=2]
		exit usage
	}
}

if (~ $cfile '') {
	echo build: missing source file >[1=2]
	exit usage
}

stem=`{echo $cfile | sed 's/.*\///;s/\.c$//'}
suffix=''
for (f in entry.*) {
	suffix=`{echo $f | sed 's/.*\.//'}
	break
}
if (~ $suffix '') {
	echo build: missing entry.* — run mk integration >[1=2]
	exit noentry
}

cc=$suffix^c
obj=$stem.$suffix

$cc -Iinclude -Isrc -o $obj $cfile
if (! ~ $status '') {
	echo build: compile failed >[1=2]
	exit fail
}

./link.rc -o $out $obj
exit $status
